
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  /// CUID primary key – opaque, non-sequential for security
  id String @id @default(cuid())

  /// Must match the UID in Firebase Auth – used to look up the admin on every request
  firebaseUid String @unique @map("firebase_uid")

  /// Admin's email – kept in sync with Firebase Auth email
  email String @unique

  /// True only for the one allowed admin account
  isAdmin Boolean @default(false) @map("is_admin")

  /// Soft-disable the admin without deleting the Firebase account
  isActive Boolean @default(true) @map("is_active")

  /// Stamped on every successful login for audit purposes
  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
